{
	"name": "asgard",
	"private": true,
	"packageManager": "pnpm@10.29.3",
	"pnpm": {
		"onlyBuiltDependencies": [
			"argon2",
			"lefthook"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@vitest/coverage-v8": "^4.0.18",
		"lefthook": "^2.1.4",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"turbo": "^2.8.14"
	},
	"scripts": {
		"prepare": "lefthook install",
		"build": "turbo run build",
		"predev": "docker compose -f docker-compose.dev.yml up -d --wait && pnpm db:bootstrap",
		"dev": "hlidskjalf",
		"db:bootstrap": "POSTGRES_ADMIN_URL=postgres://heimdall:heimdall@localhost:5432/postgres pnpm --filter saga run bootstrap",
		"test:coverage": "turbo run test:coverage",
		"lint": "biome check packages/ services/",
		"lint:fix": "biome check --write packages/ services/",
		"format": "biome format --write packages/ services/",
		"env:init": "pnpm --filter grid run sync-env",
		"env:rotate": "pnpm --filter grid run sync-env -- --rotate"
	},
	"dependencies": {
		"hlidskjalf": "0.2.8"
	}
}
