{
	"name": "vali",
	"version": "0.1.0",
	"description": "Shared test utilities — vitest config, postgres testcontainers, and temp-dir helpers",
	"type": "module",
	"exports": {
		"./fixtures": {
			"types": "./src/fixtures.ts",
			"default": "./dist/fixtures.js"
		},
		"./containers": {
			"types": "./src/containers/index.ts",
			"default": "./dist/containers.js"
		},
		"./config": {
			"types": "./src/config.ts",
			"default": "./dist/config.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"@testcontainers/postgresql": "^11.12.0",
		"testcontainers": "^11.12.0",
		"vitest": "^4.0.18"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
