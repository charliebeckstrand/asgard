{
	"name": "saga",
	"version": "0.1.0",
	"description": "Data toolkit — Postgres pool, SQL builder, migrations, and Redis primitives",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./cache": {
			"types": "./src/cache/index.ts",
			"default": "./dist/cache.js"
		}
	},
	"bin": {
		"saga-bootstrap": "./src/bin/bootstrap.ts"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"bootstrap": "tsx src/bin/bootstrap.ts",
		"lint": "biome check --config-path=../.. .",
		"lint:fix": "biome check --config-path=../.. --write .",
		"format": "biome format --config-path=../.. --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"packageManager": "pnpm@10.29.3",
	"dependencies": {
		"pg": "^8.16.0",
		"redis": "^5.5.0",
		"skuld": "workspace:*",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"@types/pg": "^8.11.0",
		"grid": "workspace:*",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vali": "workspace:*",
		"vitest": "^4.0.18"
	}
}
